# ============================================================================
# AI Investment Brain — Environment Variables
# ============================================================================
# Copy this file to `.env` (local dev) or set these in your Vercel dashboard.
# All variables except DATABASE_URL are optional — sensible defaults are used.
# ============================================================================

# ─── Database (REQUIRED) ────────────────────────────────────────────────────
#
# LOCAL DEV (SQLite — auto-created):
DATABASE_URL="file:./db/custom.db"
#
# PRODUCTION (Vercel — use Neon, Supabase, or Vercel Postgres):
# Get a free PostgreSQL database at https://neon.tech or https://supabase.com
# Format: postgresql://user:password@host/database?sslmode=require
# DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/ai-brain?sslmode=require"
# (The select-schema.js script auto-detects SQLite vs PostgreSQL from DATABASE_URL.
#  On Vercel, it forces PostgreSQL even if DATABASE_URL is missing during postinstall.)

# ─── AI / LLM (REQUIRED on Vercel) ──────────────────────────────────────────
#
# The app uses the z-ai-web-dev-sdk inside the Z.ai sandbox (auto-configured).
# On Vercel/serverless, you need to provide LLM credentials. Pick ONE provider:
#
# ─── Option A: OpenAI (most common, works everywhere) ──────────────────────
# Get a key at https://platform.openai.com/api-keys
# OPENAI_API_KEY="sk-proj-..."
# OPENAI_BASE_URL="https://api.openai.com/v1"   # default, usually don't change
# OPENAI_MODEL="gpt-4o-mini"                     # default — cheap + fast
#
# ─── Option B: GLM-4 (Z.ai's public API) ───────────────────────────────────
# Get a key at https://open.bigmodel.cn (Z.ai's public API portal)
# OPENAI_API_KEY="your-glm-key"
# OPENAI_BASE_URL="https://open.bigmodel.cn/api/paas/v4"
# OPENAI_MODEL="glm-4-flash"                     # free tier, fast
#
# ─── Option C: Groq (fast + generous free tier) ────────────────────────────
# Get a key at https://console.groq.com/keys
# OPENAI_API_KEY="gsk_..."
# OPENAI_BASE_URL="https://api.groq.com/openai/v1"
# OPENAI_MODEL="llama-3.3-70b-versatile"
#
# ─── Option D: Any OpenAI-compatible API ───────────────────────────────────
# Together.ai, Fireworks, Anyscale, Ollama, vLLM, etc.
# OPENAI_API_KEY="..."
# OPENAI_BASE_URL="https://your-provider.com/v1"
# OPENAI_MODEL="..."

# ─── Email (OPTIONAL) ───────────────────────────────────────────────────────
# If not set, emails are logged to /download/email-log.txt as stubs (works in dev).
# For real email delivery, configure SMTP (Gmail, SendGrid, Mailgun, etc.).
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"  # Gmail: use App Password, not your regular password
# EMAIL_FROM="AI Investment Brain <your-email@gmail.com>"

# ─── Market Data (OPTIONAL — default is Yahoo, no key needed) ───────────────
# Yahoo Finance works out of the box. For real-time WebSocket data or higher
# rate limits, add Finnhub and/or Polygon keys.
# MARKET_DATA_PROVIDER="yahoo"  # 'yahoo' (default) | 'finnhub' | 'polygon'
# FINNHUB_API_KEY="your-finnhub-key"  # Get at https://finnhub.io
# POLYGON_API_KEY="your-polygon-key"  # Get at https://polygon.io

# ─── Cron Security (OPTIONAL but recommended on Vercel) ─────────────────────
# Vercel Cron hits /api/cron/* endpoints. Set a secret to prevent abuse.
# Generate one: openssl rand -hex 32
# CRON_SECRET="your-random-secret-here"
# Then in vercel.json crons, the headers will be auto-set by Vercel.

# ─── App URL (OPTIONAL — used in email templates for absolute links) ────────
# NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
