// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// AI Investment Brain — Notes & Knowledge (Obsidian-style)
// ============================================================================

model Note {
  id          String   @id @default(cuid())
  title       String
  content     String   @default("") // Markdown source
  tags        String   @default("[]") // JSON array of tag strings
  tickerRefs  String   @default("[]") // JSON array of tickers mentioned (e.g. ["AAPL","NVDA"])
  links       String   @default("[]") // JSON array of wiki-link targets (titles)
  pinned      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([title])
  @@index([updatedAt])
}

// ============================================================================
// AI Investment Brain — Email Automation
// ============================================================================

model ScheduledEmail {
  id            String   @id @default(cuid())
  name          String
  recipient     String
  subject       String
  template      String   @default("custom") // morning-brief | portfolio-review | signal-alert | dcf-deepdive | custom
  cronExpr      String   @default("0 8 * * *") // default: 8am daily
  ticker        String?  // optional ticker context for the AI research
  portfolioJson String?  // optional JSON portfolio for risk/portfolio templates
  enabled       Boolean  @default(true)
  lastRunAt     DateTime?
  nextRunAt     DateTime?
  lastStatus    String?  // success | error | pending
  lastError     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([enabled, nextRunAt])
}

model EmailLog {
  id            String   @id @default(cuid())
  scheduledEmailId String?
  recipient     String
  subject       String
  body          String
  status        String   // sent | failed | stub-logged
  error         String?
  sentAt        DateTime @default(now())

  @@index([sentAt])
  @@index([scheduledEmailId])
}

// ============================================================================
// AI Investment Brain — Portfolio & Watchlist
// ============================================================================

model PortfolioPosition {
  id              String   @id @default(cuid())
  symbol          String   @unique
  description     String
  quantity        Float
  avgCostBasis    Float
  costBasisTotal  Float
  type            String   @default("Cash") // Cash | Margin | Short | Option
  source          String   @default("manual") // manual | imported
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([symbol])
}

model WatchlistItem {
  id              String   @id @default(cuid())
  symbol          String   @unique
  name            String?
  notes           String?
  addedAt         DateTime @default(now())

  @@index([symbol])
}

model SentimentArticle {
  id              String   @id @default(cuid())
  ticker          String   // ticker OR "MARKET" for general market news
  source          String   // yahoo | reddit | google | twitter | rss
  title           String
  url             String   @unique
  summary         String?
  sentiment       String   @default("neutral") // bullish | bearish | neutral
  sentimentScore  Float    @default(0)         // -1.0 to 1.0
  publishedAt     DateTime?
  fetchedAt       DateTime @default(now())

  @@index([ticker, fetchedAt])
  @@index([source])
}
