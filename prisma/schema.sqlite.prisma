// SQLite variant — for local development.
// This file is a reference; the active schema is generated by scripts/select-schema.js
// at build time based on DATABASE_URL.
//
// Usage:
//   DATABASE_URL="file:./db/custom.db"
//   (no DB_PROVIDER needed)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Models are identical between SQLite and PostgreSQL variants.
// See schema.prisma for the full model definitions.
